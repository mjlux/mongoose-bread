{
    "include": [
        "./src/**/*.ts", 
        "./tests/**/*.ts"
    ],
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "emitDeclarationOnly": true,
        "isolatedModules": true,
        "outDir": "./dist",
        "allowJs": false,
        "target": "ES6"
    },
    "exclude": [
        "./node_modules/**/*"
    ]
}